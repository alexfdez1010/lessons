---
/**
 * Footer.astro — light, simple site footer.
 * Wordmark + tagline, a compact nav, and a copyright line.
 */
import { getLangFromUrl, useTranslations, localizePath, type Lang } from '@/i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = getLangFromUrl(Astro.url) } = Astro.props;
const t = useTranslations(lang);

const year = new Date().getFullYear();

const links: { label: string; href: string }[] = [
  { label: t('nav.catalog'), href: localizePath('/catalog', lang) },
  { label: t('nav.roadmap'), href: localizePath('/roadmap', lang) },
  { label: 'RSS', href: '/rss.xml' },
];
---

<footer class="mt-24 border-t border-ink-200 bg-surface">
  <div
    class="mx-auto flex max-w-6xl flex-col gap-8 px-4 py-12 sm:px-6 md:flex-row md:items-start md:justify-between"
  >
    <div class="max-w-sm">
      <a
        href={localizePath('/', lang)}
        class="flex items-center gap-2.5 font-display text-lg font-semibold tracking-tight text-ink-900"
      >
        <span
          class="grid h-7 w-7 place-items-center rounded-[0.55rem] bg-gradient-to-br from-brand-500 to-accent-500 text-white shadow-soft"
        >
          <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" aria-hidden="true">
            <path
              d="M12 3l2.2 5.6L20 11l-5.8 2.4L12 19l-2.2-5.6L4 11l5.8-2.4L12 3z"
              fill="currentColor"
            ></path>
          </svg>
        </span>
        <span>Lessons</span>
      </a>
      <p class="mt-3 text-sm leading-relaxed text-ink-500">
        {t('footer.tagline')}
      </p>
    </div>

    <nav aria-label="Footer" class="flex flex-col gap-2.5 text-sm">
      <span class="font-medium text-ink-800">Explore</span>
      {
        links.map((link) => (
          <a href={link.href} class="text-ink-500 transition-colors hover:text-brand-700">
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>

  <div class="border-t border-ink-100">
    <div class="mx-auto max-w-6xl px-4 py-5 text-xs text-ink-400 sm:px-6">
      © {year} Lessons. {t('footer.built')}
    </div>
  </div>
</footer>
