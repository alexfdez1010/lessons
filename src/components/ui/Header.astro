---
/**
 * Header.astro — sticky translucent site chrome.
 * Wordmark on the left, primary nav on the right. Active link styling is
 * derived from the current pathname (no JS). Collapses gracefully on small
 * screens to wordmark + Catalog.
 */
const path = Astro.url.pathname;

const links: { label: string; href: string }[] = [
  { label: 'Catalog', href: '/catalog' },
  { label: 'Roadmap', href: '/roadmap' },
];

/** A link is active when the pathname matches or sits beneath its href. */
const isActive = (href: string) => path === href || path.startsWith(`${href}/`);
---

<header
  class="sticky top-0 z-50 w-full border-b border-ink-200 bg-surface/80 backdrop-blur supports-[backdrop-filter]:bg-surface/70"
>
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6">
    <!-- Wordmark -->
    <a
      href="/"
      class="group flex items-center gap-2.5 font-display text-lg font-semibold tracking-tight text-ink-900"
    >
      <span
        class="relative grid h-8 w-8 place-items-center rounded-[0.6rem] bg-gradient-to-br from-brand-500 to-accent-500 text-white shadow-soft transition-transform duration-200 group-hover:scale-105"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" aria-hidden="true">
          <path
            d="M12 3l2.2 5.6L20 11l-5.8 2.4L12 19l-2.2-5.6L4 11l5.8-2.4L12 3z"
            fill="currentColor"
          ></path>
        </svg>
      </span>
      <span>Lessons</span>
    </a>

    <!-- Nav -->
    <nav aria-label="Primary" class="flex items-center gap-1 sm:gap-2">
      {
        links.map((link) => (
          <a
            href={link.href}
            aria-current={isActive(link.href) ? 'page' : undefined}
            class:list={[
              'rounded-pill px-3 py-1.5 text-sm font-medium transition-colors',
              isActive(link.href)
                ? 'text-brand-700'
                : 'text-ink-600 hover:bg-surface-sunken hover:text-ink-900',
              // Hide secondary links on the smallest screens, keep Catalog.
              link.href === '/catalog' ? '' : 'hidden sm:inline-block',
            ]}
          >
            {link.label}
          </a>
        ))
      }

      <a
        href="#"
        aria-label="GitHub repository"
        class="ml-1 grid h-9 w-9 place-items-center rounded-pill text-ink-600 transition-colors hover:bg-surface-sunken hover:text-ink-900"
      >
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true">
          <path
            fill-rule="evenodd"
            clip-rule="evenodd"
            d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49 0-.24-.01-.87-.01-1.71-2.78.62-3.37-1.37-3.37-1.37-.45-1.18-1.11-1.49-1.11-1.49-.91-.64.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.37-2.22-.26-4.56-1.14-4.56-5.06 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05a9.36 9.36 0 0 1 5 0c1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.93-2.34 4.79-4.57 5.05.36.32.68.94.68 1.9 0 1.37-.01 2.48-.01 2.82 0 .27.18.6.69.49A10.26 10.26 0 0 0 22 12.25C22 6.58 17.52 2 12 2z"
          ></path>
        </svg>
      </a>
    </nav>
  </div>
</header>
