---
/**
 * Home (Español) — una landing pura: vende el proyecto y lleva al catálogo.
 * Los temas/lecciones viven en /es/catalog.
 * Gemelo en inglés: src/pages/index.astro.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Reveal } from '@/components/react';
import { useTranslations, localizePath, alternates as alternatesFor } from '@/i18n/utils';

const lang = 'es' as const;
const t = useTranslations(lang);

const alts = alternatesFor(Astro.url).map((a) => ({ lang: a.lang, href: a.path }));
const catalogHref = localizePath('/catalog', lang);

const valueProps = [
  {
    icon: '📖',
    title: 'Para que se te quede',
    body: 'Explicaciones cortas y claras con comprobaciones rápidas, para que lo recuerdes al día siguiente y no solo mientras lees.',
  },
  {
    icon: '🧩',
    title: 'Aprendes haciendo',
    body: 'Cada lección lleva ejercicios dentro: test, cuestionarios y guías paso a paso. Practicas, no te limitas a leer por encima.',
  },
  {
    icon: '🌍',
    title: 'En español e inglés',
    body: 'Cada lección existe en los dos idiomas y puedes cambiar de uno a otro con un solo clic.',
  },
];
---

<BaseLayout
  title={t('hero.cta.start')}
  description="Lecciones gratuitas, interactivas y animadas que enseñan cualquier tema desde cero — lee, míralo encajar y ponte a prueba. En español e inglés."
  lang={lang}
  alternates={alts}
  mainClass="mx-auto w-full max-w-6xl px-4 sm:px-6"
>
  <!-- Hero -->
  <Reveal client:visible as="section" className="py-20 text-center sm:py-28">
    <span
      class="inline-flex items-center gap-2 rounded-pill border border-brand-200 bg-brand-50 px-4 py-1.5 text-sm font-medium text-brand-700 shadow-soft"
    >
      ✨ Aprende cualquier cosa, de forma visual
    </span>
    <h1
      class="mx-auto mt-6 max-w-3xl font-display text-4xl font-bold leading-tight tracking-tight text-ink-900 sm:text-6xl"
    >
      Entiende por fin cualquier tema,
      <span class="bg-gradient-to-r from-brand-600 to-accent-500 bg-clip-text text-transparent">
        desde cero</span
      >.
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-ink-600">
      Explicaciones claras, animaciones que hacen encajar lo difícil y ejercicios en cada lección
      para que se te quede. Es gratis, es bilingüe y no hay que registrarse: abre una lección y
      empieza.
    </p>
    <div class="mt-9 flex flex-wrap items-center justify-center gap-4">
      <a
        href={catalogHref}
        class="inline-flex items-center rounded-pill bg-brand-600 px-7 py-3 text-base font-semibold text-white shadow-lift transition-all hover:bg-brand-700 hover:shadow-soft"
      >
        {t('hero.cta.start')}
      </a>
    </div>
    <p class="mt-6 text-sm text-ink-500">Gratis para siempre · Sin cuenta · Español e inglés</p>
  </Reveal>

  <!-- Por qué funciona -->
  <Reveal client:visible as="section" className="pb-12">
    <div class="grid gap-8 rounded-card border border-ink-200 bg-surface-muted p-8 sm:grid-cols-3 sm:p-12">
      {
        valueProps.map((v) => (
          <div>
            <div class="mb-3 text-3xl">{v.icon}</div>
            <h3 class="font-display text-lg font-semibold text-ink-900">{v.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-600">{v.body}</p>
          </div>
        ))
      }
    </div>
  </Reveal>

  <!-- CTA final -->
  <Reveal client:visible as="section" className="pb-20">
    <div
      class="rounded-card bg-gradient-to-br from-brand-600 to-accent-500 px-8 py-14 text-center text-white shadow-lift sm:px-12"
    >
      <h2 class="font-display text-2xl font-bold sm:text-3xl">Elige algo y empieza a aprender</h2>
      <p class="mx-auto mt-3 max-w-xl text-brand-50">
        Echa un vistazo al catálogo y métete en lo que te llame la atención. Son unos diez segundos.
      </p>
      <a
        href={catalogHref}
        class="mt-8 inline-flex items-center rounded-pill bg-white px-7 py-3 text-base font-semibold text-brand-700 shadow-soft transition-all hover:bg-brand-50"
      >
        {t('hero.cta.catalog')}
      </a>
    </div>
  </Reveal>
</BaseLayout>
