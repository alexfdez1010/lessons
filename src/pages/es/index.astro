---
/**
 * Home (Español) — una landing pura: vende el proyecto y lleva al catálogo.
 * Los temas/lecciones viven en /es/catalog.
 * Gemelo en inglés: src/pages/index.astro.
 *
 * Orden narrativo (una escalera de conversión, no una lista de funciones):
 * promesa (hero) → por qué funciona (banda de valor) → el camino (escalera
 * cero→experto) → prueba de amplitud (marquesina de cursos) → prueba de
 * producto (widgets en vivo) → método (cómo enseña una lección) → rutas
 * curadas → CTA final.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  Reveal,
  CompoundingCurve,
  PresentValueDecay,
  RiskReturnRace,
  ReturnDistribution,
} from '@/components/react';
import { useTranslations, localizePath, alternates as alternatesFor } from '@/i18n/utils';
import { getTopics, getLessons } from '@/lib/content';
import { getRoadmapSummaries } from '@/lib/roadmaps';

const lang = 'es' as const;
const t = useTranslations(lang);

// Recuentos en vivo desde el catálogo — nunca a mano.
const topics = await getTopics(lang);
const lessons = await getLessons(lang);
const courseCount = topics.length;
const lessonCount = lessons.length;
const totalMinutes = lessons.reduce((sum, l) => sum + (l.entry.data.minutes ?? 0), 0);
const totalHours = Math.round(totalMinutes / 60);

const alts = alternatesFor(Astro.url).map((a) => ({ lang: a.lang, href: a.path }));
const catalogHref = localizePath('/catalog', lang);
const interestHref = localizePath('/interest-and-yield', lang);
const tvmHref = localizePath('/money-time-value', lang);
const metricsHref = localizePath('/investment-metrics', lang);

// Cada URL de lección — la usa un manejador de clic para que "sorpréndeme"
// caiga en una lección aleatoria nueva en cada clic (no fijada al construir).
const lessonHrefs = lessons.map((l) => localizePath(`/${l.topicSlug}/${l.lessonSlug}`, lang));

const roadmaps = await getRoadmapSummaries(lang);
const difficultyLabels = {
  beginner: t('difficulty.beginner'),
  intermediate: t('difficulty.intermediate'),
  advanced: t('difficulty.advanced'),
  expert: t('difficulty.expert'),
};

// La escalera cero→experto, con recuentos de cursos en vivo por nivel.
type Tier = 'beginner' | 'intermediate' | 'advanced' | 'expert';
const tierOrder: Tier[] = ['beginner', 'intermediate', 'advanced', 'expert'];
const tierCount = (tier: Tier) => topics.filter((tp) => tp.entry.data.difficulty === tier).length;
const ladder: { tier: Tier; blurb: string; offset: string }[] = [
  {
    tier: 'beginner',
    blurb: 'Qué es siquiera el dinero. Interés, inflación, presupuestos, tu primera inversión.',
    offset: 'lg:mt-24',
  },
  {
    tier: 'intermediate',
    blurb: 'Mercados, fondos y ETFs, bonos, préstamos, stablecoins, AMMs.',
    offset: 'lg:mt-16',
  },
  {
    tier: 'advanced',
    blurb: 'Teoría de carteras, Sharpe y Sortino, modelos de factores, trampas conductuales.',
    offset: 'lg:mt-8',
  },
  {
    tier: 'expert',
    blurb: 'Precios de opciones, griegas, Value-at-Risk, Kelly, Monte Carlo, MEV.',
    offset: 'lg:mt-0',
  },
];

// Filas de la marquesina — cada curso como chip clicable, en dos cintas.
const chips = topics.map((tp) => ({
  href: localizePath(`/${tp.slug}`, lang),
  icon: tp.entry.data.icon,
  title: tp.entry.data.title,
}));
const chipRowA = chips.filter((_, i) => i % 2 === 0);
const chipRowB = chips.filter((_, i) => i % 2 === 1);

const valueProps = [
  {
    no: '01',
    title: 'Empiezas desde cero absoluto',
    body: 'Sin dar por sabido ningún ticker, balance ni tecnicismo. El primer curso asume que nunca has pensado en el dinero a propósito — y cada curso posterior solo se apoya en los anteriores.',
  },
  {
    no: '02',
    title: 'Lo toqueteas, no lo lees',
    body: 'Controles, carreras, guías paso a paso y cuestionarios en cada lección. La idea se mueve cuando tú la mueves, que es la diferencia entre "leí eso" y "lo entiendo".',
  },
  {
    no: '03',
    title: 'No se queda en lo básico',
    body: 'La mayoría de explicaciones de finanzas se rinden justo tras el interés compuesto. Estas siguen subiendo — alfa, beta, Sharpe, Sortino, drawdown, leer una ficha de fondo real — hasta que lo avanzado es solo lo que ya sabes.',
  },
];

const method = [
  {
    no: '1',
    title: 'Adivina antes de que te lo cuenten',
    body: 'Las lecciones abren con una pregunta que aún no puedes responder. Comprometerte con una respuesta primero es lo que hace que la de verdad se quede — es el efecto test, y está en cada lección.',
  },
  {
    no: '2',
    title: 'Agarra la idea',
    body: 'Cada concepto clave trae un control, una carrera o una animación. Aquí la capitalización no es una fórmula — es una curva que doblas con tus propias manos.',
  },
  {
    no: '3',
    title: 'Demuestra que lo pillas',
    body: 'Cuestionarios, emparejar conceptos, huecos por rellenar y preguntas trampa — variados a propósito, repartidos por la lección, nunca un muro de test al final.',
  },
  {
    no: '4',
    title: 'Aprueba el final',
    body: 'Cada curso termina en un examen final con nota: un intento por pregunta, sin repetir, puntuación al acabar. El progreso se guarda en tu dispositivo — sin cuenta, nunca.',
  },
];

const trust = ['Gratis para siempre', 'Sin cuenta', 'Sin anuncios', 'Código abierto', 'Español + English'];
---

<BaseLayout
  title={t('home.seoTitle')}
  description="Lecciones de finanzas gratuitas, interactivas y animadas que te llevan de cero conocimientos a experto total — lee, míralo encajar y ponte a prueba. En español e inglés."
  lang={lang}
  alternates={alts}
  mainClass="mx-auto w-full max-w-6xl px-4 sm:px-6"
>
  <!-- Hero — pitch a la izquierda, widget de lección en vivo a la derecha -->
  <section class="relative grid items-center gap-12 py-16 sm:py-20 lg:grid-cols-[1.05fr_1fr]">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
      <div
        class="absolute -top-32 left-1/2 h-112 w-4xl -translate-x-1/2 rounded-full bg-brand-200/40 blur-3xl"
      >
      </div>
      <div class="absolute -right-24 top-40 h-72 w-72 rounded-full bg-accent-300/30 blur-3xl">
      </div>
    </div>

    <Reveal client:visible>
      <div
        class="flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-xs uppercase tracking-widest text-ink-500"
      >
        <span><span class="font-bold text-ink-900">{courseCount}</span> cursos</span>
        <span class="text-ink-300">/</span>
        <span><span class="font-bold text-ink-900">{lessonCount}</span> lecciones</span>
        {
          totalHours > 0 && (
            <>
              <span class="text-ink-300">/</span>
              <span>
                <span class="font-bold text-ink-900">~{totalHours}h</span> de aprendizaje
              </span>
            </>
          )
        }
        <span class="text-ink-300">/</span>
        <span><span class="font-bold text-ink-900">0</span> requisitos</span>
      </div>
      <h1
        class="mt-5 font-display text-4xl font-bold leading-[1.05] tracking-tight text-ink-900 sm:text-6xl"
      >
        Aprende finanzas como<br class="hidden sm:block" /> aprendiste a
        <span class="relative whitespace-nowrap">
          <span class="absolute inset-x-0 bottom-1 -z-10 h-3.5 bg-accent-300/50"></span>
          montar en bici
        </span>.
      </h1>
      <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-600">
        No memorizando definiciones — agarrando la cosa y sintiendo cómo se mueve. Empieza sin saber
        qué es el interés compuesto; acaba leyendo una ficha de fondo como un profesional.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a
          href={catalogHref}
          class="inline-flex items-center rounded-pill bg-brand-600 px-7 py-3 text-base font-semibold text-white shadow-lift transition-all hover:bg-brand-700 hover:shadow-soft"
        >
          {t('hero.cta.start')}
        </a>
        <a
          href={catalogHref}
          data-random-lesson
          data-lessons={JSON.stringify(lessonHrefs)}
          class="inline-flex items-center rounded-pill px-5 py-3 text-base font-semibold text-ink-700 underline decoration-ink-300 decoration-2 underline-offset-4 transition-colors hover:text-brand-700 hover:decoration-brand-400"
        >
          o sorpréndeme →
        </a>
      </div>
      <ul class="mt-7 flex flex-wrap gap-x-5 gap-y-2 text-sm font-medium text-ink-500">
        {
          trust.map((item) => (
            <li class="inline-flex items-center gap-1.5">
              <span aria-hidden="true" class="font-bold text-success">✓</span>
              {item}
            </li>
          ))
        }
      </ul>
    </Reveal>

    <Reveal client:visible delay={120} className="relative">
      <span
        class="absolute -top-3 left-5 z-10 -rotate-2 rounded-pill bg-ink-900 px-3 py-1 font-mono text-xs font-semibold text-white shadow-lift"
      >
        ↓ una lección real — dale al play
      </span>
      <div class="rounded-card border border-ink-200 bg-surface p-4 shadow-lift sm:p-5">
        <RiskReturnRace
          client:visible
          title="Misma rentabilidad, distinto riesgo"
          seriesLabels={['Pausado Pepe', 'Montaña Rusa']}
          metricLabels={['Rentabilidad total', 'Volatilidad (riesgo)', 'Ratio de Sharpe']}
          playLabel="Lanza la carrera"
          replayLabel="Repetir"
          caption="Ambas carteras terminan en el mismo punto por caminos completamente distintos."
        />
      </div>
    </Reveal>
  </section>

  <!-- Tres razones — banda editorial numerada -->
  <Reveal client:visible as="section" className="border-y border-ink-200 py-12">
    <div class="grid gap-x-10 gap-y-8 sm:grid-cols-3">
      {
        valueProps.map((v) => (
          <div class="relative pl-1">
            <div class="font-mono text-sm font-bold text-accent-500">{v.no}</div>
            <h3 class="mt-2 font-display text-lg font-semibold text-ink-900">{v.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-600">{v.body}</p>
          </div>
        ))
      }
    </div>
  </Reveal>

  <!-- La escalera — la promesa central: un camino continuo, de cero a experto -->
  <Reveal client:visible as="section" className="pb-8 pt-16">
    <div class="mb-12 max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-accent-600">
        Una escalera, sin huecos
      </span>
      <h2 class="mt-2 font-display text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
        Cada curso se apoya en el de abajo.
      </h2>
      <p class="mt-3 text-lg leading-relaxed text-ink-600">
        La mayoría de sitios te dan explicaciones sueltas. Esto es un único grafo de dependencias:
        cada curso solo asume los anteriores, desde "¿qué es el dinero?" hasta poner precio a
        opciones. Nunca se espera que sepas algo que no te hayan enseñado.
      </p>
    </div>

    <ol class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        ladder.map((step, i) => (
          <li
            class={`flex flex-col rounded-card border border-ink-200 p-5 shadow-soft difficulty-edge-${step.tier} ${step.offset}`}
          >
            <div class="flex items-center justify-between">
              <span class={`difficulty-badge difficulty-${step.tier}`}>
                {difficultyLabels[step.tier]}
              </span>
              <span class="font-mono text-xs text-ink-400">
                {i + 1}/{tierOrder.length}
              </span>
            </div>
            <div class="mt-4 font-display text-4xl font-bold text-ink-900">
              {tierCount(step.tier)}
              <span class="ml-1 text-sm font-semibold text-ink-500">cursos</span>
            </div>
            <p class="mt-3 text-sm leading-relaxed text-ink-600">{step.blurb}</p>
          </li>
        ))
      }
    </ol>
    <p class="mt-6 text-sm text-ink-500">
      El mapa completo vive en el <a
        href={catalogHref}
        class="font-semibold text-brand-600 underline decoration-brand-300 underline-offset-2 hover:text-brand-700"
        >catálogo</a
      > — un grafo de dependencias real que puedes seguir curso a curso.
    </p>
  </Reveal>

  <!-- Prueba de amplitud — todos los cursos, desfilando. Catálogo completo, sin teaser. -->
  <Reveal client:visible as="section" className="pb-8 pt-12">
    <div class="mb-8 max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-accent-600">
        El mapa entero
      </span>
      <h2 class="mt-2 font-display text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
        {courseCount} cursos. Estos son todos.
      </h2>
      <p class="mt-3 text-lg leading-relaxed text-ink-600">
        De tu primer euro a derivados exóticos — cada chip de abajo es un curso completo que puedes
        abrir ahora mismo.
      </p>
    </div>

    <div class="group space-y-3">
      {
        [
          { row: chipRowA, anim: 'animate-marquee' },
          { row: chipRowB, anim: 'animate-marquee-reverse' },
        ].map(({ row, anim }) => (
          <div class="overflow-hidden mask-[linear-gradient(to_right,transparent,black_8%,black_92%,transparent)]">
            <div class={`flex w-max ${anim} group-hover:[animation-play-state:paused]`}>
              {row.map((c) => (
                <a
                  href={c.href}
                  class="mr-3 inline-flex items-center gap-2 whitespace-nowrap rounded-pill border border-ink-200 bg-surface px-4 py-2 text-sm font-medium text-ink-700 shadow-soft transition-colors hover:border-brand-300 hover:text-brand-700"
                >
                  <span aria-hidden="true">{c.icon}</span>
                  {c.title}
                </a>
              ))}
              {row.map((c) => (
                <a
                  href={c.href}
                  aria-hidden="true"
                  tabindex="-1"
                  class="mr-3 inline-flex items-center gap-2 whitespace-nowrap rounded-pill border border-ink-200 bg-surface px-4 py-2 text-sm font-medium text-ink-700 shadow-soft transition-colors hover:border-brand-300 hover:text-brand-700"
                >
                  <span aria-hidden="true">{c.icon}</span>
                  {c.title}
                </a>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </Reveal>

  <!-- Escaparate en vivo — las animaciones reales de los cursos, funcionando -->
  <section class="pb-8 pt-12">
    <div class="mb-12 max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-accent-600">
        Ni diapositivas. Ni vídeos.
      </span>
      <h2 class="mt-2 font-display text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
        Cosas que puedes agarrar y estirar.
      </h2>
      <p class="mt-3 text-lg leading-relaxed text-ink-600">
        Son los widgets de verdad de dentro de los cursos — arrastra un control, dale al play, mira
        cómo se mueven los números. Venga, trastéalos.
      </p>
    </div>

    <div class="space-y-6">
      <!-- Capitalización -->
      <Reveal
        client:visible
        className="grid items-center gap-8 rounded-card border border-ink-200 bg-surface p-6 shadow-soft sm:p-8 lg:grid-cols-[1fr_1.15fr]"
      >
        <div>
          <span
            class="inline-flex items-center gap-1.5 rounded-pill bg-brand-50 px-3 py-1 text-xs font-semibold text-brand-700"
          >
            🌱 Interés y Rendimiento · Principiante
          </span>
          <h3 class="mt-4 font-display text-2xl font-bold text-ink-900">
            Por qué tu dinero hace bola de nieve.
          </h3>
          <p class="mt-2 leading-relaxed text-ink-600">
            Sube la tasa un punto y mira cómo la curva se separa de la línea recta. Ese hueco es la
            capitalización — la razón por la que empezar pronto gana a empezar fuerte.
          </p>
          <a
            href={interestHref}
            class="mt-5 inline-flex items-center gap-1 font-semibold text-brand-600 hover:text-brand-700"
          >
            Abrir el curso →
          </a>
        </div>
        <CompoundingCurve
          client:visible
          title="La capitalización se separa"
          rateLabel="Tasa anual"
          yearsLabel="Años"
          startLabel="Inicial"
          compoundLabel="Crecimiento compuesto"
          simpleLabel="Crecimiento simple"
          finalValueLabel="Valor final"
          cagrLabel="CAGR"
          caption="El crecimiento simple suma la misma cantidad cada año. El compuesto gana interés sobre el interés pasado — por eso se curva hacia arriba."
        />
      </Reveal>

      <!-- Valor actual -->
      <Reveal
        client:visible
        className="grid items-center gap-8 rounded-card border border-ink-200 bg-surface p-6 shadow-soft sm:p-8 lg:grid-cols-[1.15fr_1fr]"
      >
        <div class="lg:order-2">
          <span
            class="inline-flex items-center gap-1.5 rounded-pill bg-brand-50 px-3 py-1 text-xs font-semibold text-brand-700"
          >
            ⏳ Valor Temporal del Dinero · Principiante
          </span>
          <h3 class="mt-4 font-display text-2xl font-bold text-ink-900">
            Un euro mañana vale menos. ¿Cuánto menos exactamente?
          </h3>
          <p class="mt-2 leading-relaxed text-ink-600">
            Empuja el cobro más lejos en el futuro y la barra encoge ante tus ojos. Este gráfico es
            el motor de toda valoración que harás en tu vida.
          </p>
          <a
            href={tvmHref}
            class="mt-5 inline-flex items-center gap-1 font-semibold text-brand-600 hover:text-brand-700"
          >
            Abrir el curso →
          </a>
        </div>
        <div class="lg:order-1">
          <PresentValueDecay
            client:visible
            title="Descuento: cuánto vale hoy un euro futuro"
            rateLabel="Tasa de descuento"
            yearsLabel="Años hasta el cobro"
            futureLabel="Pago futuro"
            pvLabel="Valor actual"
            faceLabel="Valor nominal"
            presentValueLabel="Vale hoy"
            centsLabel="Céntimos por euro"
            caption="Un pago prometido pierde valor cuanto más esperas y más alta es la tasa de descuento. La curva es la capitalización al revés."
          />
        </div>
      </Reveal>

      <!-- Volatilidad = dispersión de retornos -->
      <Reveal
        client:visible
        className="grid items-center gap-8 rounded-card border border-ink-200 bg-surface p-6 shadow-soft sm:p-8 lg:grid-cols-[1fr_1.15fr]"
      >
        <div>
          <span
            class="inline-flex items-center gap-1.5 rounded-pill bg-accent-500/10 px-3 py-1 text-xs font-semibold text-accent-600"
          >
            📈 Métricas de Inversión · Avanzado
          </span>
          <h3 class="mt-4 font-display text-2xl font-bold text-ink-900">
            El «riesgo» tiene forma. Aquí está.
          </h3>
          <p class="mt-2 leading-relaxed text-ink-600">
            Dos apuestas con la misma rentabilidad media — sube la volatilidad y mira cómo una
            campana se derrama hacia las colas. Esa dispersión <em>es</em> el riesgo, y es lo que
            toda métrica del curso intenta atrapar.
          </p>
          <a
            href={metricsHref}
            class="mt-5 inline-flex items-center gap-1 font-semibold text-brand-600 hover:text-brand-700"
          >
            Abrir el curso →
          </a>
        </div>
        <ReturnDistribution
          client:visible
          title="Misma media, distinta dispersión"
          lowVolLabel="Baja volatilidad"
          highVolLabel="Alta volatilidad"
          meanLabel="Misma rentabilidad media"
          sigmaLabel="Volatilidad (σ)"
          caption="Ambas distribuciones tienen la misma media; al subir la volatilidad los retornos se dispersan más en ambas direcciones."
        />
      </Reveal>
    </div>
  </section>

  <!-- Método — cómo enseña una sola lección -->
  <Reveal client:visible as="section" className="pb-8 pt-12">
    <div class="mb-10 max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-accent-600">
        Cómo funciona una lección
      </span>
      <h2 class="mt-2 font-display text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
        Construido sobre cómo funciona la memoria de verdad.
      </h2>
      <p class="mt-3 text-lg leading-relaxed text-ink-600">
        Leer parece aprender; casi nunca lo es. Cada lección de aquí fuerza las tres cosas que sí
        funcionan: predecir, interactuar, recordar.
      </p>
    </div>

    <ol class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        method.map((m) => (
          <li class="relative rounded-card border border-ink-200 bg-surface p-5 shadow-soft">
            <span class="inline-flex h-8 w-8 items-center justify-center rounded-pill bg-brand-600 font-mono text-sm font-bold text-white">
              {m.no}
            </span>
            <h3 class="mt-3 font-display text-lg font-semibold text-ink-900">{m.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-600">{m.body}</p>
          </li>
        ))
      }
    </ol>
  </Reveal>

  <!-- Rutas de aprendizaje -->
  <Reveal client:visible as="section" className="pb-8 pt-12">
    <div class="mb-10 max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-accent-600">
        {t('roadmap.learningPaths')}
      </span>
      <h2 class="mt-2 font-display text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
        Tracks organizados, no una lista gigante.
      </h2>
      <p class="mt-3 text-lg leading-relaxed text-ink-600">
        Elige el área que te interesa y sigue el grafo de principiante a experto — o salta directo
        al curso que necesites.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        roadmaps.map((r) => {
          const href = localizePath(`/roadmap/${r.meta.tag}`, lang);
          return (
            <a
              href={href}
              class="group flex flex-col rounded-card border border-ink-200 bg-surface p-5 shadow-soft transition-all hover:-translate-y-1 hover:border-brand-300 hover:shadow-lift"
            >
              <div class="flex items-center gap-3">
                <span class="text-2xl">{r.meta.icon}</span>
                <h3 class="font-display text-lg font-semibold text-ink-900 group-hover:text-brand-700">
                  {r.meta.title.es}
                </h3>
              </div>
              <p class="mt-2 text-sm leading-relaxed text-ink-600">{r.meta.description.es}</p>
              <div class="mt-auto flex flex-wrap items-center gap-2 pt-3 text-xs font-medium text-ink-500">
                <span class="rounded-pill bg-brand-50 px-2.5 py-1 text-brand-700">
                  {r.courseCount} {t('roadmap.courses')}
                </span>
                <span class="rounded-pill bg-ink-100 px-2.5 py-1">
                  {difficultyLabels[r.minDifficulty as keyof typeof difficultyLabels]} →{' '}
                  {difficultyLabels[r.maxDifficulty as keyof typeof difficultyLabels]}
                </span>
              </div>
            </a>
          );
        })
      }
    </div>
  </Reveal>

  <!-- CTA final -->
  <Reveal client:visible as="section" className="pb-20 pt-8">
    <div
      class="relative overflow-hidden rounded-card bg-linear-to-br from-brand-600 to-accent-500 px-8 py-14 text-center text-white shadow-lift sm:px-12"
    >
      <div
        aria-hidden="true"
        class="pointer-events-none absolute -top-20 left-1/2 h-64 w-xl -translate-x-1/2 rounded-full bg-white/10 blur-3xl"
      >
      </div>
      <h2 class="font-display text-2xl font-bold sm:text-3xl">
        Empieza en cero. Acaba siendo experto.
      </h2>
      <p class="mx-auto mt-3 max-w-xl text-brand-50">
        {courseCount} cursos, {lessonCount} lecciones, una sola escalera — gratis, sin cuenta, en
        español e inglés. Son unos diez segundos para empezar.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a
          href={catalogHref}
          class="inline-flex items-center rounded-pill bg-white px-7 py-3 text-base font-semibold text-brand-700 shadow-soft transition-all hover:bg-brand-50"
        >
          {t('hero.cta.catalog')}
        </a>
        <a
          href={catalogHref}
          data-random-lesson
          data-lessons={JSON.stringify(lessonHrefs)}
          class="inline-flex items-center rounded-pill border border-white/40 px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-white/10"
        >
          o sorpréndeme →
        </a>
      </div>
    </div>
  </Reveal>

  <script>
    // Elige una lección aleatoria nueva en cada clic — aleatoria por clic, no
    // fijada al construir. Recae en el href (catálogo) si falta el JSON.
    document.querySelectorAll<HTMLAnchorElement>('a[data-random-lesson]').forEach((el) => {
      let lessons: string[] = [];
      try {
        lessons = JSON.parse(el.dataset.lessons || '[]');
      } catch {
        lessons = [];
      }
      el.addEventListener('click', (e) => {
        if (!lessons.length) return;
        e.preventDefault();
        const href = lessons[Math.floor(Math.random() * lessons.length)];
        window.location.href = href;
      });
    });
  </script>
</BaseLayout>
