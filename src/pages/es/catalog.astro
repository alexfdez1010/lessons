---
/**
 * Catálogo (Español) — cada tema como grafo de dependencias (estilo
 * roadmap.sh) para que el orden de aprendizaje y los requisitos queden claros.
 * Añadir un curso no requiere tocar este archivo: basta un MDX de tema con su
 * array `dependencies`.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { CourseGraph, type CourseNode, type TagOption } from '@/components/react';
import { getTopics, getLessons } from '@/lib/content';
import { getRoadmapSummaries } from '@/lib/roadmaps';
import { useTranslations, localizePath, alternates as alternatesFor } from '@/i18n/utils';

const lang = 'es' as const;
const t = useTranslations(lang);

const topics = await getTopics(lang);
const lessonsByTopic = await Promise.all(topics.map((tp) => getLessons(lang, tp.slug)));

const nodes: CourseNode[] = topics.map((tp, i) => ({
  slug: tp.slug,
  title: tp.entry.data.title,
  description: tp.entry.data.description,
  icon: tp.entry.data.icon,
  href: localizePath(`/${tp.slug}`, lang),
  lessons: lessonsByTopic[i].length,
  lessonSlugs: lessonsByTopic[i].map((l) => l.lessonSlug),
  accent: tp.entry.data.accent,
  difficulty: tp.entry.data.difficulty,
  dependencies: tp.entry.data.dependencies,
  tags: tp.entry.data.tags,
}));

const difficultyLabels = {
  beginner: t('difficulty.beginner'),
  intermediate: t('difficulty.intermediate'),
  advanced: t('difficulty.advanced'),
  expert: t('difficulty.expert'),
};

const alts = alternatesFor(Astro.url).map((a) => ({ lang: a.lang, href: a.path }));

const roadmapSummaries = await getRoadmapSummaries(lang);

const tagOptions: TagOption[] = roadmapSummaries.map((r) => ({
  tag: r.meta.tag,
  label: r.meta.title.es,
  icon: r.meta.icon,
}));
---

<BaseLayout
  title={t('catalog.title')}
  description={t('catalog.subtitle')}
  lang={lang}
  alternates={alts}
  mainClass="mx-auto w-full max-w-[100rem] px-4 pb-20 pt-12 sm:px-6"
>
  <header class="max-w-2xl animate-fade-up">
    <h1 class="font-display text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
      {t('catalog.title')}
    </h1>
    <p class="mt-3 text-lg leading-relaxed text-ink-600">{t('catalog.subtitle')}</p>

    <div class="mt-4 flex flex-wrap gap-2">
      {
        roadmapSummaries.map((r) => (
          <a
            href={localizePath(`/roadmap/${r.meta.tag}`, lang)}
            class="inline-flex items-center gap-1.5 rounded-pill border border-ink-200 bg-surface px-3 py-1.5 text-sm font-medium text-ink-700 shadow-soft transition-colors hover:border-brand-300 hover:text-brand-700"
            title={r.meta.description.es}
          >
            <span>{r.meta.icon}</span>
            <span>{r.meta.title.es}</span>
            <span class="rounded-pill bg-brand-50 px-1.5 py-0.5 text-xs text-brand-700">
              {r.courseCount}
            </span>
          </a>
        ))
      }
    </div>
  </header>

  <div class="mt-12">
    <CourseGraph
      client:visible
      nodes={nodes}
      lessonsLabel={t('catalog.lessons')}
      difficultyLabels={difficultyLabels}
      finishedLabel={t('catalog.completed')}
      caption={t('catalog.graphHint')}
      emptyLabel="Aún no hay temas — vuelve pronto."
      levelLabel={t('catalog.filterLevel')}
      allLevelsLabel={t('catalog.allLevels')}
      tagOptions={tagOptions}
      tagsLabel={t('catalog.filterTags')}
      allTagsLabel={t('catalog.allTags')}
    />
  </div>
</BaseLayout>
