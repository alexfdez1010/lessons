---
/**
 * Catálogo (Español) — cada tema como tarjeta con su número de lecciones.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getTopics, getLessonCount } from '@/lib/content';
import { useTranslations, localizePath, alternates as alternatesFor } from '@/i18n/utils';

const lang = 'es' as const;
const t = useTranslations(lang);

const topics = await getTopics(lang);
const counts = await Promise.all(topics.map((tp) => getLessonCount(lang, tp.slug)));

const alts = alternatesFor(Astro.url).map((a) => ({ lang: a.lang, href: a.path }));
---

<BaseLayout
  title={t('catalog.title')}
  description={t('catalog.subtitle')}
  lang={lang}
  alternates={alts}
  mainClass="mx-auto w-full max-w-6xl px-4 pb-20 pt-12 sm:px-6"
>
  <header class="max-w-2xl animate-fade-up">
    <h1 class="font-display text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
      {t('catalog.title')}
    </h1>
    <p class="mt-3 text-lg leading-relaxed text-ink-600">{t('catalog.subtitle')}</p>
  </header>

  {
    topics.length === 0 ? (
      <p class="mt-12 text-ink-500">Aún no hay temas — vuelve pronto.</p>
    ) : (
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {topics.map((tp, i) => (
          <a
            href={localizePath(`/${tp.slug}`, lang)}
            class="group flex flex-col rounded-card border border-ink-200 bg-surface p-6 shadow-soft transition-all hover:-translate-y-1 hover:border-brand-300 hover:shadow-lift"
          >
            <span class="mb-4 grid h-12 w-12 place-items-center rounded-card bg-brand-50 text-2xl">
              {tp.entry.data.icon}
            </span>
            <h2 class="font-display text-lg font-semibold text-ink-900 group-hover:text-brand-700">
              {tp.entry.data.title}
            </h2>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-ink-600">
              {tp.entry.data.description}
            </p>
            <span class="mt-4 text-xs font-medium uppercase tracking-wide text-brand-600">
              {counts[i]} {t('catalog.lessons')}
            </span>
          </a>
        ))}
      </div>
    )
  }
</BaseLayout>
