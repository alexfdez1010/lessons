---
/**
 * Home (English) — a pure landing page: it sells the project and sends
 * people to the catalog. The actual topics/lessons live at /catalog.
 * Spanish twin lives at src/pages/es/index.astro.
 *
 * Narrative order (a conversion ladder, not a feature dump):
 * promise (hero) → why it works (value band) → the path (zero→expert ladder)
 * → breadth proof (course marquee) → product proof (live widgets) → method
 * (how a lesson works) → curated paths → final CTA.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  Reveal,
  CompoundingCurve,
  PresentValueDecay,
  RiskReturnRace,
  ReturnDistribution,
} from '@/components/react';
import { useTranslations, localizePath, alternates as alternatesFor } from '@/i18n/utils';
import { getTopics, getLessons } from '@/lib/content';
import { getRoadmapSummaries, roadmapHref } from '@/lib/roadmaps';
import { getDifficultyLabels } from '@/lib/catalog';

const lang = 'en' as const;
const t = useTranslations(lang);

// Live counts straight from the catalog — never hand-maintained.
const topics = await getTopics(lang);
const lessons = await getLessons(lang);
const courseCount = topics.length;
const lessonCount = lessons.length;
const totalMinutes = lessons.reduce((sum, l) => sum + (l.entry.data.minutes ?? 0), 0);
const totalHours = Math.round(totalMinutes / 60);

const alts = alternatesFor(Astro.url).map((a) => ({ lang: a.lang, href: a.path }));
const catalogHref = localizePath('/catalog', lang);
const interestHref = localizePath('/interest-and-yield', lang);
const tvmHref = localizePath('/money-time-value', lang);
const metricsHref = localizePath('/investment-metrics', lang);

// Every lesson URL — fed to a click handler so "surprise me" lands on a fresh
// random lesson on each click (not fixed at build time).
const lessonHrefs = lessons.map((l) => localizePath(`/${l.topicSlug}/${l.lessonSlug}`, lang));

const roadmaps = await getRoadmapSummaries(lang);
const difficultyLabels = getDifficultyLabels(lang);

// The zero→expert ladder, with live course counts per tier.
type Tier = 'beginner' | 'intermediate' | 'advanced' | 'expert';
const tierOrder: Tier[] = ['beginner', 'intermediate', 'advanced', 'expert'];
const tierCount = (tier: Tier) => topics.filter((tp) => tp.entry.data.difficulty === tier).length;
const ladder: { tier: Tier; blurb: string; offset: string }[] = [
  {
    tier: 'beginner',
    blurb: 'What money even is. Interest, inflation, budgets, your first investment.',
    offset: 'lg:mt-24',
  },
  {
    tier: 'intermediate',
    blurb: 'Markets, funds and ETFs, bonds, loans, stablecoins, AMMs.',
    offset: 'lg:mt-16',
  },
  {
    tier: 'advanced',
    blurb: 'Portfolio theory, Sharpe and Sortino, factor models, behavioural traps.',
    offset: 'lg:mt-8',
  },
  {
    tier: 'expert',
    blurb: 'Options pricing, Greeks, Value-at-Risk, Kelly, Monte Carlo, MEV.',
    offset: 'lg:mt-0',
  },
];

// Marquee rows — every course as a clickable chip, split into two ribbons.
const chips = topics.map((tp) => ({
  href: localizePath(`/${tp.slug}`, lang),
  icon: tp.entry.data.icon,
  title: tp.entry.data.title,
}));
const chipRowA = chips.filter((_, i) => i % 2 === 0);
const chipRowB = chips.filter((_, i) => i % 2 === 1);

const valueProps = [
  {
    no: '01',
    title: 'Start from absolute zero',
    body: 'No ticker, no balance sheet, no jargon assumed. Course one assumes you have never thought about money on purpose — and every later course only leans on the ones before it.',
  },
  {
    no: '02',
    title: 'You poke it, not read it',
    body: 'Sliders, races, step-throughs, quizzes in every lesson. The idea moves when you move it, which is the difference between "I read that" and "I get that".',
  },
  {
    no: '03',
    title: 'It doesn’t stop at “intro”',
    body: 'Most finance explainers tap out right after compound interest. These keep climbing — alpha, beta, Sharpe, Sortino, drawdown, reading a real fund factsheet — until the advanced stuff is just stuff you know.',
  },
];

const method = [
  {
    no: '1',
    title: 'Guess before you’re told',
    body: 'Lessons open with a question you can’t answer yet. Committing to a guess first is what makes the real answer stick — it’s the testing effect, and it’s built into every lesson.',
  },
  {
    no: '2',
    title: 'Grab the idea',
    body: 'Every core concept ships with a slider, race or animation. Compounding isn’t a formula here — it’s a curve you bend with your own hands.',
  },
  {
    no: '3',
    title: 'Prove you got it',
    body: 'Quizzes, concept matchers, fill-in-the-blanks and spot-the-trap questions — varied on purpose, spaced through the lesson, never a wall of MCQs at the end.',
  },
  {
    no: '4',
    title: 'Pass the final',
    body: 'Each course ends in a graded final exam: one shot per question, no retries, score at the end. Progress saves on your device — no account, ever.',
  },
];

const trust = ['Free forever', 'No account', 'No ads', 'Open source', 'English + Español'];
---

<BaseLayout
  title={t('home.seoTitle')}
  description="Free, interactive, animated finance lessons that take you from zero knowledge to complete expert — read, watch it click, and test yourself. In English and Spanish."
  lang={lang}
  alternates={alts}
  mainClass="mx-auto w-full max-w-6xl px-4 sm:px-6"
>
  <!-- Hero — left pitch, right a live lesson widget you can play with above the fold -->
  <section class="relative grid items-center gap-12 py-16 sm:py-20 lg:grid-cols-[1.05fr_1fr]">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-y-0 left-1/2 -z-10 w-screen max-w-none -translate-x-1/2 overflow-hidden"
    >
      <!-- Central brand→accent wash, spanning the full viewport width. -->
      <div
        class="absolute -top-40 left-1/2 h-150 w-[100rem] max-w-none -translate-x-1/2 rounded-[100%] bg-[radial-gradient(closest-side,var(--color-brand-200),color-mix(in_oklab,var(--color-accent-300)_45%,transparent)_60%,transparent)] opacity-70 blur-3xl"
      >
      </div>
      <!-- Accent bloom pinned toward the right edge of the screen. -->
      <div class="absolute right-[6%] top-24 h-80 w-80 rounded-full bg-accent-300/30 blur-3xl">
      </div>
      <!-- Cool brand bloom on the left edge for balance. -->
      <div class="absolute left-[4%] top-48 h-72 w-72 rounded-full bg-brand-300/25 blur-3xl">
      </div>
    </div>

    <Reveal client:visible>
      <div
        class="flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-xs uppercase tracking-widest text-ink-500"
      >
        <span><span class="font-bold text-ink-900">{courseCount}</span> courses</span>
        <span class="text-ink-300">/</span>
        <span><span class="font-bold text-ink-900">{lessonCount}</span> lessons</span>
        {
          totalHours > 0 && (
            <>
              <span class="text-ink-300">/</span>
              <span>
                <span class="font-bold text-ink-900">~{totalHours}h</span> of learning
              </span>
            </>
          )
        }
        <span class="text-ink-300">/</span>
        <span><span class="font-bold text-ink-900">0</span> prerequisites</span>
      </div>
      <h1
        class="mt-5 font-display text-4xl font-bold leading-[1.05] tracking-tight text-ink-900 sm:text-6xl"
      >
        Learn finance the way<br class="hidden sm:block" /> you'd learn to
        <span class="relative whitespace-nowrap">
          <span class="absolute inset-x-0 bottom-1 -z-10 h-3.5 bg-accent-300/50"></span>
          ride a bike
        </span>.
      </h1>
      <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-600">
        Not by memorising definitions — by grabbing the thing and feeling how it moves. Start not
        knowing what compound interest is; finish reading a fund factsheet like a pro.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a
          href={catalogHref}
          class="inline-flex items-center rounded-pill bg-brand-600 px-7 py-3 text-base font-semibold text-white shadow-lift transition-all hover:-translate-y-0.5 hover:bg-brand-700 hover:shadow-soft"
        >
          {t('hero.cta.start')}
        </a>
        <a
          href={catalogHref}
          data-random-lesson
          data-lessons={JSON.stringify(lessonHrefs)}
          class="inline-flex items-center rounded-pill px-5 py-3 text-base font-semibold text-ink-700 underline decoration-ink-300 decoration-2 underline-offset-4 transition-colors hover:text-brand-700 hover:decoration-brand-400"
        >
          or surprise me →
        </a>
      </div>
      <ul class="mt-7 flex flex-wrap gap-x-5 gap-y-2 text-sm font-medium text-ink-500">
        {
          trust.map((item) => (
            <li class="inline-flex items-center gap-1.5">
              <span aria-hidden="true" class="font-bold text-success">✓</span>
              {item}
            </li>
          ))
        }
      </ul>
    </Reveal>

    <Reveal client:visible delay={120} className="relative">
      <span
        class="absolute -top-3 left-5 z-10 -rotate-2 rounded-pill bg-ink-900 px-3 py-1 font-mono text-xs font-semibold text-white shadow-lift"
      >
        ↓ a real lesson — press play
      </span>
      <div
        class="rounded-card border border-ink-200 bg-surface/90 p-4 shadow-lift ring-1 ring-ink-900/5 backdrop-blur-sm transition-transform hover:-translate-y-0.5 sm:p-5"
      >
        <RiskReturnRace client:visible />
      </div>
    </Reveal>
  </section>

  <!-- Three reasons — editorial numbered band -->
  <Reveal client:visible as="section" className="border-y border-ink-200 py-12">
    <div class="grid gap-x-10 gap-y-8 sm:grid-cols-3">
      {
        valueProps.map((v) => (
          <div class="relative pl-1">
            <div class="font-mono text-sm font-bold text-accent-500">{v.no}</div>
            <h3 class="mt-2 font-display text-lg font-semibold text-ink-900">{v.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-600">{v.body}</p>
          </div>
        ))
      }
    </div>
  </Reveal>

  <!-- The ladder — the core promise: one continuous path, zero to expert -->
  <Reveal client:visible as="section" className="pb-8 pt-16">
    <div class="mb-12 max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-accent-600">
        One ladder, no gaps
      </span>
      <h2 class="mt-2 font-display text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
        Every course stands on the one below it.
      </h2>
      <p class="mt-3 text-lg leading-relaxed text-ink-600">
        Most sites give you scattered explainers. This is a single dependency graph: each course
        only assumes the ones before it, from "what is money?" all the way to pricing options. You
        are never expected to know something you weren't taught.
      </p>
    </div>

    <ol class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        ladder.map((step, i) => (
          <li
            class={`flex flex-col rounded-card border border-ink-200 bg-surface/70 p-5 shadow-soft backdrop-blur-sm transition-all hover:-translate-y-1 hover:shadow-lift difficulty-edge-${step.tier} ${step.offset}`}
          >
            <div class="flex items-center justify-between">
              <span class={`difficulty-badge difficulty-${step.tier}`}>
                {difficultyLabels[step.tier]}
              </span>
              <span class="font-mono text-xs text-ink-400">
                {i + 1}/{tierOrder.length}
              </span>
            </div>
            <div class="mt-4 font-display text-4xl font-bold text-ink-900">
              {tierCount(step.tier)}
              <span class="ml-1 text-sm font-semibold text-ink-500">courses</span>
            </div>
            <p class="mt-3 text-sm leading-relaxed text-ink-600">{step.blurb}</p>
          </li>
        ))
      }
    </ol>
    <p class="mt-6 text-sm text-ink-500">
      The full map lives in the <a
        href={catalogHref}
        class="font-semibold text-brand-600 underline decoration-brand-300 underline-offset-2 hover:text-brand-700"
        >catalog</a
      > — a real dependency graph you can follow course by course.
    </p>
  </Reveal>

  <!-- Breadth proof — every course, scrolling by. Full catalog, no teaser. -->
  <Reveal client:visible as="section" className="pb-8 pt-12">
    <div class="mb-8 max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-accent-600">
        The whole map
      </span>
      <h2 class="mt-2 font-display text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
        {courseCount} courses. This is all of them.
      </h2>
      <p class="mt-3 text-lg leading-relaxed text-ink-600">
        From your first euro to exotic derivatives — every chip below is a full course you can open
        right now.
      </p>
    </div>

    <div class="group space-y-3">
      {
        [
          { row: chipRowA, anim: 'animate-marquee' },
          { row: chipRowB, anim: 'animate-marquee-reverse' },
        ].map(({ row, anim }) => (
          <div class="overflow-hidden mask-[linear-gradient(to_right,transparent,black_8%,black_92%,transparent)]">
            <div class={`flex w-max ${anim} group-hover:[animation-play-state:paused]`}>
              {row.map((c) => (
                <a
                  href={c.href}
                  class="mr-3 inline-flex items-center gap-2 whitespace-nowrap rounded-pill border border-ink-200 bg-surface px-4 py-2 text-sm font-medium text-ink-700 shadow-soft transition-colors hover:border-brand-300 hover:text-brand-700"
                >
                  <span aria-hidden="true">{c.icon}</span>
                  {c.title}
                </a>
              ))}
              {row.map((c) => (
                <a
                  href={c.href}
                  aria-hidden="true"
                  tabindex="-1"
                  class="mr-3 inline-flex items-center gap-2 whitespace-nowrap rounded-pill border border-ink-200 bg-surface px-4 py-2 text-sm font-medium text-ink-700 shadow-soft transition-colors hover:border-brand-300 hover:text-brand-700"
                >
                  <span aria-hidden="true">{c.icon}</span>
                  {c.title}
                </a>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </Reveal>

  <!-- Live showcase — the actual course animations, running -->
  <section class="pb-8 pt-12">
    <div class="mb-12 max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-accent-600">
        Not slides. Not videos.
      </span>
      <h2 class="mt-2 font-display text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
        Stuff you can actually grab and pull.
      </h2>
      <p class="mt-3 text-lg leading-relaxed text-ink-600">
        These are the real widgets from inside the courses — drag a slider, hit play, watch the
        numbers move. Go on, mess with them.
      </p>
    </div>

    <div class="space-y-6">
      <!-- Compounding -->
      <Reveal
        client:visible
        className="grid items-center gap-8 rounded-card border border-ink-200 bg-surface p-6 shadow-soft sm:p-8 lg:grid-cols-[1fr_1.15fr]"
      >
        <div>
          <span
            class="inline-flex items-center gap-1.5 rounded-pill bg-brand-50 px-3 py-1 text-xs font-semibold text-brand-700"
          >
            🌱 Interest &amp; Yield · Beginner
          </span>
          <h3 class="mt-4 font-display text-2xl font-bold text-ink-900">
            Why your money snowballs.
          </h3>
          <p class="mt-2 leading-relaxed text-ink-600">
            Nudge the rate up one point and watch the curve peel away from the straight line. That
            gap is compounding — the whole reason starting early beats starting big.
          </p>
          <a
            href={interestHref}
            class="mt-5 inline-flex items-center gap-1 font-semibold text-brand-600 hover:text-brand-700"
          >
            Open the course →
          </a>
        </div>
        <CompoundingCurve client:visible />
      </Reveal>

      <!-- Present value -->
      <Reveal
        client:visible
        className="grid items-center gap-8 rounded-card border border-ink-200 bg-surface p-6 shadow-soft sm:p-8 lg:grid-cols-[1.15fr_1fr]"
      >
        <div class="lg:order-2">
          <span
            class="inline-flex items-center gap-1.5 rounded-pill bg-brand-50 px-3 py-1 text-xs font-semibold text-brand-700"
          >
            ⏳ Time Value of Money · Beginner
          </span>
          <h3 class="mt-4 font-display text-2xl font-bold text-ink-900">
            A dollar later is worth less. Exactly how much less?
          </h3>
          <p class="mt-2 leading-relaxed text-ink-600">
            Push the payment further into the future and the bar shrinks before your eyes. This one
            chart is the engine behind every valuation you'll ever do.
          </p>
          <a
            href={tvmHref}
            class="mt-5 inline-flex items-center gap-1 font-semibold text-brand-600 hover:text-brand-700"
          >
            Open the course →
          </a>
        </div>
        <div class="lg:order-1">
          <PresentValueDecay client:visible />
        </div>
      </Reveal>

      <!-- Volatility = spread of returns -->
      <Reveal
        client:visible
        className="grid items-center gap-8 rounded-card border border-ink-200 bg-surface p-6 shadow-soft sm:p-8 lg:grid-cols-[1fr_1.15fr]"
      >
        <div>
          <span
            class="inline-flex items-center gap-1.5 rounded-pill bg-accent-500/10 px-3 py-1 text-xs font-semibold text-accent-600"
          >
            📈 Investment Metrics · Advanced
          </span>
          <h3 class="mt-4 font-display text-2xl font-bold text-ink-900">
            "Risky" has a shape. Here it is.
          </h3>
          <p class="mt-2 leading-relaxed text-ink-600">
            Two bets with the same average return — drag the volatility up and watch one bell curve
            spill into the tails. That spread <em>is</em> the risk, and it's what every metric in
            the course is trying to pin down.
          </p>
          <a
            href={metricsHref}
            class="mt-5 inline-flex items-center gap-1 font-semibold text-brand-600 hover:text-brand-700"
          >
            Open the course →
          </a>
        </div>
        <ReturnDistribution client:visible />
      </Reveal>
    </div>
  </section>

  <!-- Method — how a single lesson teaches -->
  <Reveal client:visible as="section" className="pb-8 pt-12">
    <div class="mb-10 max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-accent-600">
        How a lesson works
      </span>
      <h2 class="mt-2 font-display text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
        Built on how memory actually works.
      </h2>
      <p class="mt-3 text-lg leading-relaxed text-ink-600">
        Reading feels like learning; it mostly isn't. Every lesson here forces the three things that
        do work: predict, interact, retrieve.
      </p>
    </div>

    <ol class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        method.map((m) => (
          <li class="relative rounded-card border border-ink-200 bg-surface p-5 shadow-soft transition-all hover:-translate-y-1 hover:shadow-lift">
            <span class="inline-flex h-8 w-8 items-center justify-center rounded-pill bg-brand-600 font-mono text-sm font-bold text-white">
              {m.no}
            </span>
            <h3 class="mt-3 font-display text-lg font-semibold text-ink-900">{m.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-600">{m.body}</p>
          </li>
        ))
      }
    </ol>
  </Reveal>

  <!-- Learning Paths -->
  <Reveal client:visible as="section" className="pb-8 pt-12">
    <div class="mb-10 max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-accent-600">
        {t('roadmap.learningPaths')}
      </span>
      <h2 class="mt-2 font-display text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
        Curated tracks, not one giant list.
      </h2>
      <p class="mt-3 text-lg leading-relaxed text-ink-600">
        Pick the area you care about and follow the graph from beginner to expert — or jump straight
        to the course you need.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        roadmaps.map((r) => {
          const href = roadmapHref(r.meta.tag, lang);
          return (
            <a
              href={href}
              class="group flex flex-col rounded-card border border-ink-200 bg-surface p-5 shadow-soft transition-all hover:-translate-y-1 hover:border-brand-300 hover:shadow-lift"
            >
              <div class="flex items-center gap-3">
                <span class="text-2xl">{r.meta.icon}</span>
                <h3 class="font-display text-lg font-semibold text-ink-900 group-hover:text-brand-700">
                  {r.meta.title.en}
                </h3>
              </div>
              <p class="mt-2 text-sm leading-relaxed text-ink-600">{r.meta.description.en}</p>
              <div class="mt-auto flex flex-wrap items-center gap-2 pt-3 text-xs font-medium text-ink-500">
                <span class="rounded-pill bg-brand-50 px-2.5 py-1 text-brand-700">
                  {r.courseCount} {t('roadmap.courses')}
                </span>
                <span class="rounded-pill bg-ink-100 px-2.5 py-1">
                  {difficultyLabels[r.minDifficulty as keyof typeof difficultyLabels]} →{' '}
                  {difficultyLabels[r.maxDifficulty as keyof typeof difficultyLabels]}
                </span>
              </div>
            </a>
          );
        })
      }
    </div>
  </Reveal>

  <!-- Closing CTA -->
  <Reveal client:visible as="section" className="pb-20 pt-8">
    <div
      class="relative overflow-hidden rounded-card bg-linear-to-br from-brand-600 to-accent-500 px-8 py-14 text-center text-white shadow-lift sm:px-12"
    >
      <div
        aria-hidden="true"
        class="pointer-events-none absolute -top-20 left-1/2 h-64 w-xl -translate-x-1/2 rounded-full bg-white/10 blur-3xl"
      >
      </div>
      <h2 class="font-display text-2xl font-bold sm:text-3xl">Start at zero. Finish an expert.</h2>
      <p class="mx-auto mt-3 max-w-xl text-brand-50">
        {courseCount} courses, {lessonCount} lessons, one ladder — free, no account, in English and
        Spanish. It takes about ten seconds to start.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a
          href={catalogHref}
          class="inline-flex items-center rounded-pill bg-white px-7 py-3 text-base font-semibold text-brand-700 shadow-soft transition-all hover:bg-brand-50"
        >
          {t('hero.cta.catalog')}
        </a>
        <a
          href={catalogHref}
          data-random-lesson
          data-lessons={JSON.stringify(lessonHrefs)}
          class="inline-flex items-center rounded-pill border border-white/40 px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-white/10"
        >
          or surprise me →
        </a>
      </div>
    </div>
  </Reveal>

  <script>
    // Pick a fresh random lesson on every click — random per click, not baked
    // in at build time. Falls back to the href (catalog) if JSON is missing.
    document.querySelectorAll<HTMLAnchorElement>('a[data-random-lesson]').forEach((el) => {
      let lessons: string[] = [];
      try {
        lessons = JSON.parse(el.dataset.lessons || '[]');
      } catch {
        lessons = [];
      }
      el.addEventListener('click', (e) => {
        if (!lessons.length) return;
        e.preventDefault();
        const href = lessons[Math.floor(Math.random() * lessons.length)];
        window.location.href = href;
      });
    });
  </script>
</BaseLayout>
