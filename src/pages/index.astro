---
/**
 * Home (English) — polished landing: hero, featured topics, value props.
 * Spanish twin lives at src/pages/es/index.astro.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Reveal } from '@/components/react';
import { getTopics, getLessonCount } from '@/lib/content';
import { useTranslations, localizePath, alternates as alternatesFor } from '@/i18n/utils';

const lang = 'en' as const;
const t = useTranslations(lang);

const topics = await getTopics(lang);
const counts = await Promise.all(topics.map((tp) => getLessonCount(lang, tp.slug)));

const alts = alternatesFor(Astro.url).map((a) => ({ lang: a.lang, href: a.path }));

const startHref =
  topics.length > 0 ? localizePath(`/${topics[0].slug}`, lang) : localizePath('/catalog', lang);
const catalogHref = localizePath('/catalog', lang);

const valueProps = [
  {
    icon: '📖',
    title: 'Read, then do',
    body: 'Concise explanations paired with interactive checks so the idea actually sticks.',
  },
  {
    icon: '🧩',
    title: 'Built-in exercises',
    body: 'Multiple-choice questions, quizzes and step-throughs embedded right in each lesson.',
  },
  {
    icon: '🌍',
    title: 'Fully bilingual',
    body: 'Every lesson is available in English and Spanish, with one click to switch.',
  },
];
---

<BaseLayout
  title={t('hero.cta.start')}
  description="Interactive, animated lessons that teach any topic from scratch — read, visualize, and test yourself."
  lang={lang}
  alternates={alts}
  mainClass="mx-auto w-full max-w-6xl px-4 sm:px-6"
>
  <!-- Hero -->
  <Reveal client:visible as="section" className="py-16 text-center sm:py-24">
    <span
      class="inline-flex items-center gap-2 rounded-pill border border-brand-200 bg-brand-50 px-4 py-1.5 text-sm font-medium text-brand-700 shadow-soft"
    >
      ✨ Learn anything, visually
    </span>
    <h1
      class="mx-auto mt-6 max-w-3xl font-display text-4xl font-bold leading-tight tracking-tight text-ink-900 sm:text-6xl"
    >
      Lessons that teach any topic
      <span
        class="bg-gradient-to-r from-brand-600 to-accent-500 bg-clip-text text-transparent"
      >
        from scratch</span
      >.
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-ink-600">
      Read clear explanations, watch ideas come to life, and test yourself with exercises baked
      into every page.
    </p>
    <div class="mt-9 flex flex-wrap items-center justify-center gap-4">
      <a
        href={startHref}
        class="inline-flex items-center rounded-pill bg-brand-600 px-7 py-3 text-base font-semibold text-white shadow-lift transition-all hover:bg-brand-700 hover:shadow-soft"
      >
        {t('hero.cta.start')}
      </a>
      <a
        href={catalogHref}
        class="inline-flex items-center rounded-pill border border-ink-200 bg-surface px-7 py-3 text-base font-semibold text-ink-700 transition-all hover:border-brand-300 hover:bg-brand-50 hover:text-brand-700"
      >
        {t('hero.cta.catalog')}
      </a>
    </div>
  </Reveal>

  <!-- Featured topics -->
  <Reveal client:visible as="section" className="py-12">
    <div class="mb-8 flex items-end justify-between gap-4">
      <h2 class="font-display text-2xl font-bold text-ink-900 sm:text-3xl">{t('catalog.title')}</h2>
      <a href={catalogHref} class="text-sm font-semibold text-brand-600 hover:text-brand-700">
        {t('hero.cta.catalog')} →
      </a>
    </div>
    {
      topics.length === 0 ? (
        <p class="text-ink-500">No topics yet — check back soon.</p>
      ) : (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {topics.map((tp, i) => (
            <a
              href={localizePath(`/${tp.slug}`, lang)}
              class="group flex flex-col rounded-card border border-ink-200 bg-surface p-6 shadow-soft transition-all hover:-translate-y-1 hover:border-brand-300 hover:shadow-lift"
            >
              <span class="mb-4 grid h-12 w-12 place-items-center rounded-card bg-brand-50 text-2xl">
                {tp.entry.data.icon}
              </span>
              <h3 class="font-display text-lg font-semibold text-ink-900 group-hover:text-brand-700">
                {tp.entry.data.title}
              </h3>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-ink-600">
                {tp.entry.data.description}
              </p>
              <span class="mt-4 text-xs font-medium uppercase tracking-wide text-brand-600">
                {counts[i]} {t('catalog.lessons')}
              </span>
            </a>
          ))}
        </div>
      )
    }
  </Reveal>

  <!-- Value props -->
  <Reveal client:visible as="section" className="py-16">
    <div class="grid gap-8 rounded-card border border-ink-200 bg-surface-muted p-8 sm:grid-cols-3 sm:p-12">
      {
        valueProps.map((v) => (
          <div>
            <div class="mb-3 text-3xl">{v.icon}</div>
            <h3 class="font-display text-lg font-semibold text-ink-900">{v.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-600">{v.body}</p>
          </div>
        ))
      }
    </div>
  </Reveal>
</BaseLayout>
