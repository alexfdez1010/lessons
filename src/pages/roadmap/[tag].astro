---
/**
 * Roadmap page (English) — shows only courses tagged with a specific roadmap
 * tag, plotted as a dependency graph. The tag registry lives in
 * src/lib/roadmaps.ts; adding a course to a roadmap is just editing its
 * MDX frontmatter.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { CourseGraph, type CourseNode } from '@/components/react';
import { getTopicsByTag, roadmaps, roadmapByTag } from '@/lib/roadmaps';
import { useTranslations, localizePath, alternates as alternatesFor } from '@/i18n/utils';

export async function getStaticPaths() {
  return roadmaps.map((r) => ({ params: { tag: r.tag } }));
}

const lang = 'en' as const;
const t = useTranslations(lang);
const { tag } = Astro.params;
const meta = roadmapByTag.get(tag);
if (!meta) {
  return Astro.redirect(localizePath('/catalog', lang));
}

const topicsWithLessons = await getTopicsByTag(lang, tag);
const nodes: CourseNode[] = topicsWithLessons.map(({ topic, lessons, lessonSlugs }) => ({
  slug: topic.slug,
  title: topic.entry.data.title,
  description: topic.entry.data.description,
  icon: topic.entry.data.icon,
  href: localizePath(`/${topic.slug}`, lang),
  lessons,
  lessonSlugs,
  accent: topic.entry.data.accent,
  difficulty: topic.entry.data.difficulty,
  dependencies: topic.entry.data.dependencies,
}));

const difficultyLabels = {
  beginner: t('difficulty.beginner'),
  intermediate: t('difficulty.intermediate'),
  advanced: t('difficulty.advanced'),
  expert: t('difficulty.expert'),
};

const title = `${meta.title.en} — ${t('roadmap.learningPaths')}`;
const description = meta.description.en;

const alts = alternatesFor(Astro.url).map((a) => ({ lang: a.lang, href: a.path }));
const catalogHref = localizePath('/catalog', lang);
---

<BaseLayout
  title={title}
  description={description}
  lang={lang}
  alternates={alts}
  mainClass="mx-auto w-full max-w-[100rem] px-4 pb-20 pt-12 sm:px-6"
>
  <header class="max-w-2xl animate-fade-up">
    <div class="flex items-center gap-3">
      <span class="text-3xl">{meta.icon}</span>
      <h1 class="font-display text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
        {meta.title.en}
      </h1>
    </div>
    <p class="mt-3 text-lg leading-relaxed text-ink-600">{description}</p>
    <p class="mt-2 text-sm text-ink-500">
      {nodes.length} {t('roadmap.courses')}
    </p>
    <a
      href={catalogHref}
      class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-brand-600 hover:text-brand-700"
    >
      ← {t('roadmap.backToCatalog')}
    </a>
  </header>

  <div class="mt-12">
    <CourseGraph
      client:visible
      nodes={nodes}
      lessonsLabel={t('catalog.lessons')}
      difficultyLabels={difficultyLabels}
      finishedLabel={t('catalog.completed')}
      caption={t('catalog.graphHint')}
      emptyLabel={t('roadmap.empty')}
      levelLabel={t('catalog.filterLevel')}
      allLevelsLabel={t('catalog.allLevels')}
    />
  </div>
</BaseLayout>
