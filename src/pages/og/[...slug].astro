---
/**
 * og/[...slug].astro — per-page Open Graph cards.
 *
 * Renders one 1200×630 branded card for every real page that needs a share
 * image: the catalog, each topic and each lesson, for BOTH locales. The
 * `slug` param mirrors the page pathname minus its leading slash, so
 * ogCardRoute(pathname) (src/lib/og.ts) resolves to one of these routes:
 *
 *   page '/es/transformers/attention'
 *     -> ogCardRoute -> '/og/es/transformers/attention'
 *     -> slug param  -> 'es/transformers/attention'
 *
 * scripts/generate-og.ts screenshots each into public/og/<ogSlug>.png.
 *
 * (The home cards are produced by og/default.astro instead.)
 */
import OgCard from '@/pages/og/_OgCard.astro';
import { SITE } from '@/lib/site';
import { getTopics, getLessons } from '@/lib/content';
import { localizePath, useTranslations, locales } from '@/i18n/utils';

export async function getStaticPaths() {
  const paths: {
    params: { slug: string };
    props: { eyebrow?: string; title: string; subtitle?: string; icon?: string };
  }[] = [];

  /** page pathname '/es/catalog' -> slug param 'es/catalog'. */
  const toSlug = (pathname: string) => pathname.replace(/^\/+/, '');

  for (const lang of locales) {
    const t = useTranslations(lang);

    // Localized home card for NON-default locales (e.g. '/es' -> '/og/es').
    // The default-locale home ('/') is produced by og/default.astro instead,
    // and og/default.astro emits the 'default' slug, so we skip it here.
    const homePath = localizePath('/', lang);
    if (homePath !== '/') {
      paths.push({
        params: { slug: toSlug(homePath) },
        props: {
          eyebrow: '✦ Lessons',
          title: SITE.titleTemplate(),
          subtitle: SITE.description,
        },
      });
    }

    // Catalog landing card.
    paths.push({
      params: { slug: toSlug(localizePath('/catalog', lang)) },
      props: {
        eyebrow: '✦ Lessons',
        title: t('catalog.title'),
        subtitle: t('catalog.subtitle'),
      },
    });

    // One card per topic.
    const topics = await getTopics(lang);
    for (const { slug, entry } of topics) {
      paths.push({
        params: { slug: toSlug(localizePath(`/${slug}`, lang)) },
        props: {
          eyebrow: `${entry.data.icon} ${entry.data.title}`,
          title: entry.data.title,
          subtitle: entry.data.tagline ?? entry.data.description,
          icon: entry.data.icon,
        },
      });
    }

    // One card per lesson.
    const lessons = await getLessons(lang);
    for (const { topicSlug, lessonSlug, entry } of lessons) {
      const topic = topics.find((x) => x.slug === topicSlug);
      paths.push({
        params: { slug: toSlug(localizePath(`/${topicSlug}/${lessonSlug}`, lang)) },
        props: {
          eyebrow: topic ? `${topic.entry.data.icon} ${topic.entry.data.title}` : 'Lessons',
          title: entry.data.title,
          subtitle: entry.data.description,
          icon: topic?.entry.data.icon,
        },
      });
    }
  }

  return paths;
}

const { eyebrow, title, subtitle, icon } = Astro.props;
---

<OgCard eyebrow={eyebrow} title={title} subtitle={subtitle} icon={icon} />
