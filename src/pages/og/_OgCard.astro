---
/**
 * _OgCard.astro — the shared 1200×630 Open Graph card.
 *
 * Underscore-prefixed so Astro does NOT route it; it's a partial consumed by
 * og/default.astro and og/[...slug].astro. Each instance is screenshotted by
 * scripts/generate-og.ts to public/og/<slug>.png.
 *
 * The card is a standalone document: global.css is imported explicitly (the
 * Header/Footer layouts that normally inject it are intentionally absent) so
 * Tailwind tokens (brand/accent/ink, font-display, shadow-lift…) are available.
 */
import '@/styles/global.css';
import { SITE } from '@/lib/site';

interface Props {
  /** Small uppercase label above the title (topic name, icon + word, …). */
  eyebrow?: string;
  /** Large display headline. */
  title: string;
  /** Supporting description under the title. */
  subtitle?: string;
  /** Optional emoji/icon shown large in the corner. */
  icon?: string;
}

const { eyebrow, title, subtitle, icon } = Astro.props;
---

<!doctype html>
<html lang={SITE.lang}>
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta name="robots" content="noindex" />
  </head>
  <body>
    <!-- The exact 1200×630 capture target. generate-og.ts screenshots #og-card. -->
    <div id="og-card" class="card">
      <div class="glow glow-a"></div>
      <div class="glow glow-b"></div>

      <div class="inner">
        <header class="brand">
          <span class="mark" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="40" height="40" fill="none">
              <path
                d="M12 3l2.2 5.6L20 11l-5.8 2.4L12 19l-2.2-5.6L4 11l5.8-2.4L12 3z"
                fill="currentColor"></path>
            </svg>
          </span>
          <span class="wordmark">{SITE.name}</span>
        </header>

        <div class="body">
          {eyebrow && <p class="eyebrow">{eyebrow}</p>}
          <h1 class="title">{title}</h1>
          {subtitle && <p class="subtitle">{subtitle}</p>}
        </div>

        <footer class="meta">
          <span class="domain">lessons.alejandrofernandezcamello.me</span>
          {icon && <span class="icon" aria-hidden="true">{icon}</span>}
        </footer>
      </div>
    </div>

    <style>
      :global(html),
      :global(body) {
        margin: 0;
        padding: 0;
        background: #fff;
      }

      .card {
        position: relative;
        width: 1200px;
        height: 630px;
        overflow: hidden;
        /* Blue gradient: brand-700 → brand-500 → accent-500. */
        background:
          radial-gradient(120% 140% at 12% 8%, var(--color-accent-400) 0%, transparent 46%),
          linear-gradient(135deg, var(--color-brand-800) 0%, var(--color-brand-600) 48%, var(--color-accent-600) 100%);
        color: #fff;
        font-family: var(--font-sans);
      }

      /* Soft decorative blobs for depth. */
      .glow {
        position: absolute;
        border-radius: 999px;
        filter: blur(80px);
        opacity: 0.45;
      }
      .glow-a {
        width: 520px;
        height: 520px;
        top: -180px;
        right: -120px;
        background: var(--color-accent-300);
      }
      .glow-b {
        width: 460px;
        height: 460px;
        bottom: -200px;
        left: -100px;
        background: var(--color-brand-400);
      }

      .inner {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 100%;
        box-sizing: border-box;
        padding: 72px 80px;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 16px;
      }
      .mark {
        display: grid;
        place-items: center;
        width: 64px;
        height: 64px;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.16);
        border: 1px solid rgba(255, 255, 255, 0.28);
        color: #fff;
        box-shadow: var(--shadow-lift);
      }
      .wordmark {
        font-family: var(--font-display);
        font-size: 34px;
        font-weight: 700;
        letter-spacing: -0.02em;
      }

      .body {
        max-width: 980px;
      }
      .eyebrow {
        margin: 0 0 18px;
        font-family: var(--font-display);
        font-size: 24px;
        font-weight: 600;
        letter-spacing: 0.02em;
        text-transform: uppercase;
        color: var(--color-accent-300);
      }
      .title {
        margin: 0;
        font-family: var(--font-display);
        font-size: 78px;
        line-height: 1.04;
        font-weight: 700;
        letter-spacing: -0.03em;
        color: #fff;
        /* Clamp very long titles to keep the card balanced. */
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .subtitle {
        margin: 28px 0 0;
        font-size: 30px;
        line-height: 1.4;
        font-weight: 400;
        color: rgba(255, 255, 255, 0.85);
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .domain {
        font-family: var(--font-mono);
        font-size: 22px;
        color: rgba(255, 255, 255, 0.78);
      }
      .icon {
        font-size: 56px;
        line-height: 1;
      }
    </style>
  </body>
</html>
