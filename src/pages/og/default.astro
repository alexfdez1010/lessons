---
/**
 * og/default.astro — the GENERIC site OG card.
 *
 * Renders the 1200×630 branded fallback card screenshotted by
 * scripts/generate-og.ts into public/og/default.png (the slug 'default'
 * defined by ogSlug('/') in src/lib/og.ts). Referenced by SITE.defaultOgImage.
 *
 * This is NOT a normal page: no Header/Footer, no SEO chrome — just the card.
 */
import OgCard from '@/pages/og/_OgCard.astro';
import { SITE } from '@/lib/site';
---

<OgCard
  eyebrow="✦ Lessons"
  title="Learn anything, visually."
  subtitle={SITE.description}
/>
