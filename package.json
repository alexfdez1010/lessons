{
  "name": "lessons",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "bun run check:latex && astro check && tsc --noEmit",
    "check:latex": "bun run scripts/check-latex.ts",
    "audit": "bun audit",
    "audit:fix": "bun update && bun audit",
    "og:generate": "bun run scripts/generate-og.ts",
    "og:build": "astro build && bun run og:generate",
    "pre-commit": "bun run audit:fix && bun run check && astro build && bun run og:generate"
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.1",
    "@astrojs/react": "^5.0.6",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vercel": "^10.0.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/lexend": "^5.2.11",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vercel/analytics": "^2.0.1",
    "astro": "^6.4.2",
    "mermaid": "^11.15.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/typography": "^0.5.19",
    "katex": "^0.17.0",
    "playwright": "^1.60.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "yaml": ">=2.8.3",
    "path-to-regexp": ">=6.3.0 <7"
  }
}